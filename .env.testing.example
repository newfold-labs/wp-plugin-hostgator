# WP-Browser / Codeception wpunit and PHPUnit (wp-phpunit) configuration
# Copy to .env.testing and adjust for your environment or CI.
# https://wpbrowser.wptestkit.dev/
# These defaults match the reusable codecoverage workflow (MySQL on 33306, MYSQL_DATABASE=tests-wordpress).

# WordPress root (e.g. from johnpbloch/wordpress or wp-env)
WP_ROOT_FOLDER="wordpress"

# Database (CI: workflow MySQL service creates only "tests-wordpress"; use that name for CI)
TEST_DB_HOST="127.0.0.1"
TEST_DB_PORT="33306"
TEST_DB_USER="root"
TEST_DB_PASSWORD="password"

TEST_DB_NAME="tests-wordpress"
TEST_TABLE_PREFIX="wp_"

# Site identifiers (used by wp-browser and by PHPUnit wp-tests-config.php)
TEST_SITE_WP_DOMAIN="localhost:8888"
TEST_SITE_ADMIN_EMAIL="email@example.org"

# Optional: PHPUnit WP test suite (defaults used if unset)
# WP_TESTS_TITLE="Test"
# WP_PHP_BINARY="php"
